{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "artisan",
                "boost:mcp"
            ]
        },
        "tailwindcss": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "tailwindcss-mcp-server"
            ]
        },
        "daisyui-blueprint": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "daisyui-blueprint@latest"
            ]
        }
    }
}