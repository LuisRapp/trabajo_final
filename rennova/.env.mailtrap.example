# Configuración de Mailtrap para Notificaciones de Mantenimiento
# Obtén tus credenciales en: https://mailtrap.io/inboxes

MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=tu_username_aqui
MAIL_PASSWORD=tu_password_aqui
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=mantenimiento@rennova.com
MAIL_FROM_NAME="${APP_NAME}"

# Email del administrador que recibirá las notificaciones
ADMIN_EMAIL=admin@rennova.com
